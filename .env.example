# Environment Variables สำหรับ GEM-GPT-Hub
# คัดลอกไฟล์นี้เป็น .env.local และใส่ค่าจริง

# Google Gemini AI (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration (สำหรับ Authentication & Database)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Error Monitoring (Sentry)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENABLED=false

# App Configuration
VITE_APP_NAME=GEM-GPT-Hub
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development
VITE_APP_URL=http://localhost:3000

# Backend API (ถ้ามี Express server)
VITE_API_BASE_URL=http://localhost:3001/api

# AI Studio Configuration (สำหรับ deployment)
APP_URL=MY_APP_URL
